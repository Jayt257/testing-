    {
      "id": "b1",
      "type": "text",
      "title": "Hindi Consonants and Daily Life",
      "body": "This week, you learn how Hindi sounds use the tongue and breath in different ways. The most important idea is contrast: some letters are soft, some are aspirated, and some are retroflex. Do not rush; practice a few sounds every day."
    },
    {
      "id": "b2",
      "type": "grammar_rule",
      "title": "This and that",
      "pattern": "यह = this, वह = that",
      "examples": [
        {
          "hi": "यह घर है।",
          "romanization": "यह घर है।",
          "en": "This is a house."
        },
        {
          "hi": "वह किताब है।",
          "romanization": "वह किताब है।",
          "en": "That is a book."
        },
        {
          "hi": "यह मेरा स्कूल है।",
          "romanization": "यह मेरा स्कूल है।",
          "en": "This is my school."
        }
      ],
      "note": "Use यह for near objects and वह for things farther away."
    },
    {
      "id": "b3",
      "type": "dialogue",
      "title": "Conversation Practice",
      "speakers": [
        "Speaker A",
        "Speaker B"
      ],
      "lines": [
        {
          "speaker": 0,
          "text": "यह क्या है?",
          "romanization": "Yah kyā hai?",
          "translation": "What is this?"
        },
        {
          "speaker": 1,
          "text": "यह किताब है।",
          "romanization": "Yah kitāb hai.",
          "translation": "This is a book."
        },
        {
          "speaker": 0,
          "text": "किताब कहाँ है?",
          "romanization": "Kitāb kahā̃ hai?",
          "translation": "Where is the book?"
        },
        {
          "speaker": 1,
          "text": "किताब मेज़ पर है।",
          "romanization": "Kitāb mez par hai.",
          "translation": "The book is on the table."
        }
      ]
    },
