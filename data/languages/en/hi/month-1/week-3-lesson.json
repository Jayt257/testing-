      "title": "Numbers, Time, and Question Words",
      "body": "In Hindi, counting and asking simple questions help you handle daily life. Today you will practice numbers, days, and the most common question words. Keep the rhythm steady and speak with confidence."
    },
    {
      "id": "b2",
      "type": "grammar_rule",
      "title": "Question words",
      "pattern": "कौन / क्या / कब / कहाँ / क्यों / कैसे",
      "examples": [
        {
          "hi": "आप कौन हैं?",
          "romanization": "आप कौन हैं?",
          "en": "Who are you?"
        },
        {
          "hi": "यह क्या है?",
          "romanization": "यह क्या है?",
          "en": "What is this?"
        },
        {
          "hi": "आप कहाँ रहते हैं?",
          "romanization": "आप कहाँ रहते हैं?",
          "en": "Where do you live?"
        }
      ],
      "note": "Question words usually stay near the start of the sentence."
