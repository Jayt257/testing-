        {
          "speaker": 1,
          "text": "अब तीन बजे हैं।",
          "romanization": "Ab teen baje hain.",
          "translation": "It is 3 o'clock now."
        },
        {
          "speaker": 0,
          "text": "आज क्या दिन है?",
          "romanization": "Aaj kyā din hai?",
          "translation": "What day is it today?"
        },
        {
          "speaker": 1,
          "text": "आज सोमवार है।",
          "romanization": "Aaj somvār hai.",
          "translation": "Today is Monday."
