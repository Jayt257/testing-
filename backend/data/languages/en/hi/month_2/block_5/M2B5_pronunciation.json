  "instructions": "Practice saying these modal phrases. Pay special attention to the nasal 'n' sounds in 'Humein' and 'Tumhein', and the aspirated 'chh' in 'Chahiye'.",
  "targetPhrasesOrWords": [
    {
      "itemId": "p_1",
      "targetText": "सकता",
      "transliteration": "Sakta",
      "baseTranslation": "Can (masc)",
      "phoneticHint": "suk-taa",
      "syllableSplit": "sak-ta",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'sack-ta'. The 'a' in 'sak' is a short schwa, like the 'u' in 'sun'."
    },
    {
      "itemId": "p_2",
      "targetText": "चाहिए",
      "transliteration": "Chahiye",
      "baseTranslation": "Should / Want",
      "phoneticHint": "chaa-hee-yeh",
      "syllableSplit": "cha-hi-ye",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'chai-yeh' (like the tea). It must be three distinct syllables."
    },
    {
      "itemId": "p_3",
      "targetText": "पड़ेगा",
      "transliteration": "Padega",
      "baseTranslation": "Will have to",
      "phoneticHint": "puh-day-gaa",
      "syllableSplit": "pa-de-ga",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Pronouncing a hard 'd' like in 'dog'. The 'd' in 'padega' is a retroflex flap (the tongue taps the roof of the mouth)."
    },
    {
      "itemId": "p_4",
      "targetText": "मुझे",
      "transliteration": "Mujhe",
      "baseTranslation": "To me (I should...)",
      "phoneticHint": "moo-jhay",
      "syllableSplit": "mu-jhe",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'moo-jee'. The 'jh' is breathy/aspirated."
    },
    {
      "itemId": "p_5",
      "targetText": "तुम्हें",
      "transliteration": "Tumhein",
      "baseTranslation": "To you (You casual should...)",
      "phoneticHint": "toom-hay(n)",
      "syllableSplit": "tum-hein",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Forgetting the nasalization at the end. It's not a hard 'n', but an echo in the nose."
    },
    {
      "itemId": "p_6",
      "targetText": "हमें",
      "transliteration": "Humein",
      "baseTranslation": "To us (We should...)",
      "phoneticHint": "huh-may(n)",
      "syllableSplit": "hu-mein",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'hoo-main'. Start with a short schwa 'hu'."
    },
    {
      "itemId": "p_7",
      "targetText": "पीनी चाहिए",
      "transliteration": "Peeni chahiye",
      "baseTranslation": "Should drink (fem object)",
      "phoneticHint": "pee-nee chaa-hee-yeh",
      "syllableSplit": "pee-ni cha-hi-ye",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'peena chahiye' when talking about tea. The 'ni' ending must be sharp."
    }
