      "syllableSplit": "jaa-un-ga",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying a hard 'n' (jaa-un-ga). The tongue should not touch the roof of the mouth for the 'n'."
    },
    {
      "itemId": "p_2",
      "targetText": "जाऊँगी",
      "transliteration": "Jaungi",
      "baseTranslation": "will go (Female 'I')",
