      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'chai-yay' (like the tea). It must be three distinct syllables: chaa - hi - ye."
    },
    {
      "itemId": "p_2",
      "targetText": "मुझे",
