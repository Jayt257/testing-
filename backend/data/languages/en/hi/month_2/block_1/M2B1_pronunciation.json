      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'moo-jay'. The 'jh' needs a strong puff of air, and the 'u' is short."
    },
    {
      "itemId": "p_3",
      "targetText": "आपको",
