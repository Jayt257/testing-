    {
      "itemId": "p_7",
      "targetText": "ड",
      "transliteration": "da",
      "baseTranslation": "Retroflex 'd'",
      "phoneticHint": "d-uh (curl tongue back)",
      "syllableSplit": "da",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Using the English soft 'd'."
