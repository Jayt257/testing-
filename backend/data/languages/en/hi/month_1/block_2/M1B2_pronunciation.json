      "syllableSplit": "kha",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying it like a regular 'k'. Must expel air from the chest."
    },
    {
      "itemId": "p_3",
