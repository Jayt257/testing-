      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying the English 't' where the tongue touches the teeth. Tongue must hit the roof."
    },
    {
      "itemId": "p_6",
      "targetText": "ठ",
      "transliteration": "tha",
      "baseTranslation": "Aspirated retroflex 't'",
      "phoneticHint": "th-huh (curl tongue + air)",
      "syllableSplit": "tha",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'th' like in 'the' or 'think'. It is a hard T with air."
