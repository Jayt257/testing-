    {
      "wordId": "v1",
      "targetText": "मैंने कल भारतीय खाना खाया।",
      "transliteration": "Maine kal bhartiya khaana khaaya.",
      "baseTranslation": "I ate Indian food yesterday."
    },
    {
      "wordId": "v3",
      "targetText": "मुझे घर जाना है।",
      "transliteration": "Mujhe ghar jaana hai.",
      "baseTranslation": "I want to go home."
    },
    {
      "wordId": "v5",
      "targetText": "आप क्या काम करते हैं?",
      "transliteration": "Aap kya kaam karte hain?",
      "baseTranslation": "What work do you do?"
    },
    {
      "wordId": "v6",
      "targetText": "कृपया मुझे एक गिलास पानी दीजिए।",
      "transliteration": "Kripya mujhe ek glass paani dijiye.",
      "baseTranslation": "Please give me a glass of water."
    },
    {
      "wordId": "v8",
      "targetText": "राहुल मेरा बहुत अच्छा दोस्त है।",
      "transliteration": "Rahul mera bahut accha dost hai.",
      "baseTranslation": "Rahul is my very good friend."
    },
    {
      "wordId": "v11",
      "targetText": "मेरे पास समय नहीं है।",
      "transliteration": "Mere paas samay nahi hai.",
      "baseTranslation": "I don't have time."
    },
    {
      "wordId": "v15",
      "targetText": "मदद के लिए धन्यवाद।",
      "transliteration": "Madad ke liye dhanyawad.",
      "baseTranslation": "Thank you for the help."
    },
    {
      "wordId": "v16",
      "targetText": "दिल्ली एक बहुत बड़ी जगह है।",
      "transliteration": "Delhi ek bahut badi jagah hai.",
      "baseTranslation": "Delhi is a very big place."
    },
