  "title": "Pronunciation: Fusing the Compound Verb",
  "learningGoal": "Pronounce compound verbs fluidly, ensuring the root verb and vector verb sound like a single cohesive unit.",
  "difficultyLevel": "advanced",
  "baseLanguage": "en",
