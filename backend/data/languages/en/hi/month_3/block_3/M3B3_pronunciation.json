  "instructions": "In spoken Hindi, compound verbs are said rapidly without a pause in between. 'Bata diya' should sound almost like a single word. Practice blending these verbs together.",
  "targetPhrasesOrWords": [
    {
      "itemId": "p_1",
      "targetText": "बता दिया",
      "transliteration": "Bata diya",
      "baseTranslation": "Told (outward)",
      "phoneticHint": "buh-taa-dee-yaa",
      "syllableSplit": "ba-ta di-ya",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Pausing between 'bata' and 'diya'. They must flow together instantly."
    },
    {
      "itemId": "p_2",
      "targetText": "समझ ली",
      "transliteration": "Samajh li",
      "baseTranslation": "Understood (inward)",
      "phoneticHint": "suh-mujh lee",
      "syllableSplit": "sa-majh li",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Ignoring the 'h' in 'samajh'. It must be aspirated before transitioning to 'li'."
    },
    {
      "itemId": "p_3",
      "targetText": "सो गया",
      "transliteration": "So gaya",
      "baseTranslation": "Fell asleep",
      "phoneticHint": "so guh-yaa",
      "syllableSplit": "so ga-ya",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'sew gaya'. The 'o' in 'so' is pure and round, not a diphthong."
    },
    {
      "itemId": "p_4",
      "targetText": "मार डाला",
      "transliteration": "Maar daala",
      "baseTranslation": "Killed / Smashed",
      "phoneticHint": "maar daa-laa",
      "syllableSplit": "maar daa-la",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Using a soft 'd' for 'daala'. It must be a hard, retroflex 'D' (tongue curled back to the roof of the mouth)."
    },
    {
      "itemId": "p_5",
      "targetText": "रो पड़ी",
      "transliteration": "Ro padi",
      "baseTranslation": "Burst into tears (Feminine)",
      "phoneticHint": "ro puh-dee",
      "syllableSplit": "ro pa-di",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Pronouncing 'padi' with a regular D. It is a retroflex flap (the tongue snaps forward)."
    },
    {
      "itemId": "p_6",
      "targetText": "पी लिया",
      "transliteration": "Pee liya",
      "baseTranslation": "Drank up",
      "phoneticHint": "pee lee-yaa",
      "syllableSplit": "pee li-ya",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Shortening the 'ee' in 'Pee'. It must be a long, distinct 'Pee' followed directly by 'li-ya'."
    },
    {
      "itemId": "p_7",
      "targetText": "आ जाओ",
      "transliteration": "Aa jao",
      "baseTranslation": "Arrive / Come on over",
      "phoneticHint": "aa jaa-oh",
      "syllableSplit": "aa ja-o",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Slurring it into 'Aajo'. The two distinct 'A' sounds must be maintained: 'Aa' then 'jaa-o'."
    }
  ],
