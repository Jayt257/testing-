  "exampleSentences": [
    {
      "wordId": "v1",
      "targetText": "यहाँ सबसे पास अस्पताल कहाँ है?",
      "transliteration": "Yahan sabse paas aspataal kahan hai?",
      "baseTranslation": "Where is the nearest hospital here?"
    },
    {
      "wordId": "v3",
      "targetText": "मेरे पेट में बहुत दर्द है।",
      "transliteration": "Mere pet mein bahut dard hai.",
      "baseTranslation": "There is a lot of pain in my stomach."
    },
    {
      "wordId": "v5",
      "targetText": "डॉक्टर ने मुझे बुखार की दवा दी।",
      "transliteration": "Doctor ne mujhe bukhar ki dawa di.",
      "baseTranslation": "The doctor gave me medicine for fever."
    },
    {
      "wordId": "v6",
      "targetText": "मुझे चक्कर आ रहे हैं।",
      "transliteration": "Mujhe chakkar aa rahe hain.",
      "baseTranslation": "I am feeling dizzy."
    },
    {
      "wordId": "v8",
      "targetText": "उसे सिर पर चोट लगी है।",
      "transliteration": "Use sir par chot lagi hai.",
      "baseTranslation": "He has an injury on his head."
    },
    {
      "wordId": "v11",
      "targetText": "मेरा सामान चोरी हो गया है।",
      "transliteration": "Mera saaman chori ho gaya hai.",
      "baseTranslation": "My luggage has been stolen."
    },
    {
      "wordId": "v13",
      "targetText": "मैं पुलिस में शिकायत करूँगा।",
      "transliteration": "Main police mein shikayat karoonga.",
      "baseTranslation": "I will make a complaint to the police."
    },
    {
      "wordId": "v14",
      "targetText": "कृपया मेरी मदद कीजिए!",
      "transliteration": "Kripya meri madad kijiye!",
      "baseTranslation": "Please help me!"
    },
    {
      "wordId": "v16",
      "targetText": "मेरा पासपोर्ट गायब है।",
      "transliteration": "Mera passport gaayab hai.",
      "baseTranslation": "My passport is missing."
    },
    {
      "wordId": "v18",
      "targetText": "तुरंत यहाँ आइए!",
      "transliteration": "Turant yahan aaiye!",
      "baseTranslation": "Come here immediately!"
    }
  ],
