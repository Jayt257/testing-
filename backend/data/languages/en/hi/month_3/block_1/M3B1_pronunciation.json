  "instructions": "In a conditional sentence, the voice rises during the 'Agar' clause, pauses at 'Toh', and then falls during the result clause. Practice these rhythmic sentences.",
  "targetPhrasesOrWords": [
    {
      "itemId": "p_1",
      "targetText": "अगर तुम आओगे,",
      "transliteration": "Agar tum aaoge,",
      "baseTranslation": "If you come,",
      "phoneticHint": "uh-gur toom aa-oh-gay",
      "syllableSplit": "a-gar tum aa-o-ge",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'Ah-gar' with a long A. It is a short, sharp schwa: uh-gar."
    },
    {
      "itemId": "p_2",
      "targetText": "तो मैं जाऊँगा।",
      "transliteration": "toh main jaunga.",
      "baseTranslation": "then I will go.",
      "phoneticHint": "toh may(n) jaa-oon-gaa",
      "syllableSplit": "toh main ja-un-ga",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Pronouncing 'Toh' as 'Two'. It rhymes with 'Go' or 'So'."
    },
    {
      "itemId": "p_3",
      "targetText": "अगर मेरे पास पैसे होते,",
      "transliteration": "Agar mere paas paise hote,",
      "baseTranslation": "If I had money,",
      "phoneticHint": "uh-gur may-ray paas pay-say ho-tay",
      "syllableSplit": "a-gar me-re paas pai-se ho-te",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Failing to raise the pitch at the end of the clause ('hote'). The rising pitch signals that the sentence is not over."
    },
    {
      "itemId": "p_4",
      "targetText": "तो मैं खरीदता।",
      "transliteration": "toh main khareedta.",
      "baseTranslation": "then I would buy.",
      "phoneticHint": "toh may(n) khuh-reed-taa",
      "syllableSplit": "toh main kha-reed-ta",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'kha-rid-ta' with a soft D. The 'r' is tapped, and the 'd' is a soft dental D (tongue touching teeth)."
    },
    {
      "itemId": "p_5",
      "targetText": "अगर बारिश हुई भी,",
      "transliteration": "Agar baarish hui bhi,",
      "baseTranslation": "Even if it rained,",
      "phoneticHint": "uh-gur baa-rish hoo-ee bhee",
      "syllableSplit": "a-gar baa-rish hu-i bhi",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Failing to aspirate the 'bh' in 'bhi'. It must be a breathy B."
    },
    {
      "itemId": "p_6",
      "targetText": "फिर भी मैं आऊँगा।",
      "transliteration": "phir bhi main aaunga.",
      "baseTranslation": "even then I will come.",
      "phoneticHint": "feer bhee may(n) aa-oon-gaa",
      "syllableSplit": "phir bhi main aa-un-ga",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'fir'. While 'fir' is common in casual Hindi, the standard pronunciation is an aspirated P: 'phir'."
    },
    {
      "itemId": "p_7",
      "targetText": "वक्त मिला, तो",
      "transliteration": "Waqt mila, toh",
      "baseTranslation": "[If] time is found, then",
      "phoneticHint": "vukt mi-laa, toh",
      "syllableSplit": "waqt mi-la toh",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'wah-kut'. The 'q' and 't' are clustered together: waqt."
    }
  ],
