  "title": "Pronunciation: Emphasizing the Pivot (Toh)",
  "learningGoal": "Master the intonation contour of conditional sentences, specifically pausing and emphasizing the connecting word 'Toh'.",
  "difficultyLevel": "advanced",
  "baseLanguage": "en",
  "targetLanguage": "hi",
