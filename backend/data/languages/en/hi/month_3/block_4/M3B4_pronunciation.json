      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'Hastachar'. The 'ksha' is a combination of K and SH. Has-taak-shar."
    },
    {
      "itemId": "p_3",
      "targetText": "प्रतीक्षा",
      "transliteration": "Pratiksha",
      "baseTranslation": "Wait / Waiting",
      "phoneticHint": "pruh-teek-shaa",
      "syllableSplit": "pra-teek-sha",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'Par-tik-sha'. The 'pra' is a cluster. The P and R happen simultaneously: Pra."
    },
    {
      "itemId": "p_4",
      "targetText": "समस्या",
      "transliteration": "Samasya",
      "baseTranslation": "Problem",
      "phoneticHint": "suh-mus-yaa",
