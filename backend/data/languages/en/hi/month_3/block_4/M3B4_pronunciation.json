      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Using a hard English 'D'. The 'dh' must be soft (dental) and breathy."
    },
    {
      "itemId": "p_6",
      "targetText": "प्रारंभ",
      "transliteration": "Prarambh",
      "baseTranslation": "Beginning",
      "phoneticHint": "praa-rumbh",
      "syllableSplit": "praa-rambh",
      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Ignoring the final 'bh'. It ends with a strong, breathy B."
    },
    {
      "itemId": "p_7",
      "targetText": "क्या मैं आऊँ?",
      "transliteration": "Kya main aaun?",
