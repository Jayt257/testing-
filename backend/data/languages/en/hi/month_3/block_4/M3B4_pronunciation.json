      "nativeAudioRef": "dummy_audio.mp3",
      "slowAudioRef": "dummy_slow_audio.mp3",
      "commonMispronunciation": "Saying 'Samasiya'. The S and Y are glued together: mas-ya."
    },
    {
      "itemId": "p_5",
      "targetText": "अनुरोध",
      "transliteration": "Anurodh",
      "baseTranslation": "Request",
      "phoneticHint": "uh-noo-rodh (aspirated dh)",
