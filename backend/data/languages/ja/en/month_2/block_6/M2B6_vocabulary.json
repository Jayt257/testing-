  "exampleSentences": [
    {
      "wordId": "v1",
      "targetText": "Where is the station?",
      "transliteration": "ウェア イズ ザ ステーション？",
      "baseTranslation": "駅はどこですか？"
    },
    {
      "wordId": "v4",
      "targetText": "How do I get to the airport?",
      "transliteration": "ハウ ドゥー アイ ゲット トゥ ザ エアポート？",
      "baseTranslation": "空港にはどうやって行けばいいですか？"
    },
    {
      "wordId": "v6",
      "targetText": "Go straight.",
      "transliteration": "ゴー ストレイト",
      "baseTranslation": "まっすぐ進んでください。"
    },
    {
      "wordId": "v11",
      "targetText": "Turn left at the corner.",
      "transliteration": "ターン レフト アット ザ コーナー",
      "baseTranslation": "角を左に曲がってください。"
    },
    {
      "wordId": "v12",
      "targetText": "Turn right at the traffic light.",
      "transliteration": "ターン ライト アット ザ トラフィック ライト",
      "baseTranslation": "信号を右に曲がってください。"
    },
    {
      "wordId": "v9",
      "targetText": "The bank is next to the museum.",
      "transliteration": "ザ バンク イズ ネクスト トゥ ザ ミュージアム",
      "baseTranslation": "銀行は博物館の隣にあります。"
    },
    {
      "wordId": "v10",
      "targetText": "The hospital is across from the station.",
      "transliteration": "ザ ホスピタル イズ アクロス フロム ザ ステーション",
      "baseTranslation": "病院は駅の向かいにあります。"
    }
  ],
