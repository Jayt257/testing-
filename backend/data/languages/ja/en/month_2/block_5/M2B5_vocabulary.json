  "exampleSentences": [
    {
      "wordId": "v1",
      "targetText": "I can swim very fast.",
      "transliteration": "アイ キャン スイム ヴェリー ファスト",
      "baseTranslation": "私はとても速く泳ぐことができます。"
    },
    {
      "wordId": "v3",
      "targetText": "You must not drive here.",
      "transliteration": "ユー マス ノット ドライヴ ヒア",
      "baseTranslation": "ここで運転してはいけません。"
    },
    {
      "wordId": "v4",
      "targetText": "You must not smoke in the hospital.",
      "transliteration": "ユー マス ノット スモーク イン ザ ホスピタル",
      "baseTranslation": "病院でタバコを吸ってはいけません。"
    },
    {
      "wordId": "v6",
      "targetText": "You can park your car here.",
      "transliteration": "ユー キャン パーク ユア カー ヒア",
      "baseTranslation": "ここに車を駐車できますよ。"
    },
    {
      "wordId": "v10",
      "targetText": "You have to practice every day.",
      "transliteration": "ユー ハフ トゥ プラクティス エヴリー デイ",
      "baseTranslation": "毎日練習しなければなりません。"
    }
  ],
