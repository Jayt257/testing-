      "sectionId": "sec_1",
      "sectionTitle": "Grammar: Polite Requests (丁寧なお願い)",
      "questions": [
        {
          "questionId": "q1",
          "questionText": "「手伝ってくれませんか？」と見知らぬ人に丁寧に頼む時、最も適切なのはどれですか？",
          "questionType": "multiple_choice",
          "options": [
            "Can you help me?",
            "Could you help me?",
            "Do you help me?",
            "May I help you?"
          ],
          "questionHints": null,
          "marks": 10,
          "correctAnswerRef": "adminCorrectAnswerSet.answerKey.q1"
        },
        {
          "questionId": "q2",
          "questionText": "「お水を持ってきていただけますか？」の正しい英語はどれですか？",
          "questionType": "multiple_choice",
          "options": [
            "Could you bring me some water?",
            "May I bring some water?",
            "I would like bring some water.",
            "Do you want bring some water?"
          ],
          "questionHints": null,
          "marks": 10,
          "correctAnswerRef": "adminCorrectAnswerSet.answerKey.q2"
        },
        {
          "questionId": "q3",
          "questionText": "「パスポートを拝見してもよろしいでしょうか？」と許可を求める時、最も丁寧なのはどれですか？",
          "questionType": "multiple_choice",
          "options": [
            "Can I see your passport?",
            "Could you see my passport?",
            "May I see your passport?",
            "I want to see your passport."
          ],
          "questionHints": null,
          "marks": 10,
          "correctAnswerRef": "adminCorrectAnswerSet.answerKey.q3"
        }
      ]
    },
    {
