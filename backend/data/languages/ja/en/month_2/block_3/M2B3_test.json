          "questionHints": null,
          "marks": 10,
          "correctAnswerRef": "adminCorrectAnswerSet.answerKey.q4"
        },
        {
          "questionId": "q5",
          "questionText": "お客様に「何かお飲み物はいかがですか？」と勧める時、正しいのはどれですか？",
          "questionType": "multiple_choice",
          "options": [
            "Do you want something to drink?",
            "Would you like something to drink?",
            "Are you drink something?",
            "Could you drink something?"
