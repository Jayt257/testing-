  "exampleSentences": [
    {
      "wordId": "v1",
      "targetText": "Please inform me if you need anything.",
      "transliteration": "プリーズ インフォーム ミー イフ ユー ニード エニシング",
      "baseTranslation": "何か必要なものがあれば私にお知らせください。"
    },
    {
      "wordId": "v3",
      "targetText": "I received your email yesterday.",
      "transliteration": "アイ レシーヴド ユア イーメール イエスタデイ",
      "baseTranslation": "昨日、あなたのメールを受け取りました。"
    },
    {
      "wordId": "v5",
      "targetText": "We need to discuss the new project.",
      "transliteration": "ウィー ニード トゥ ディスカス ザ ニュー プロジェクト",
      "baseTranslation": "私たちは新しいプロジェクトについて話し合う必要があります。"
    },
    {
      "wordId": "v6",
      "targetText": "I apologize for the delay.",
      "transliteration": "アイ アポロジャイズ フォー ザ ディレイ",
      "baseTranslation": "遅れについて謝罪いたします。"
    },
    {
      "wordId": "v8",
      "targetText": "I appreciate your assistance.",
      "transliteration": "アイ アプリーシエイト ユア アシスタンス",
      "baseTranslation": "あなたのご支援に感謝します。"
    },
    {
      "wordId": "v9",
      "targetText": "Are you available on Tuesday?",
      "transliteration": "アー ユー アヴェイラブル オン チューズデイ？",
      "baseTranslation": "火曜日は空いていますか？"
    },
    {
      "wordId": "v11",
      "targetText": "Can we postpone the meeting?",
      "transliteration": "キャン ウィー ポストポーン ザ ミーティング？",
      "baseTranslation": "会議を延期できますか？"
    }
  ],
