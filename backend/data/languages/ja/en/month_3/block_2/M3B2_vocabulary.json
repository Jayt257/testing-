  "exampleSentences": [
    {
      "wordId": "v1",
      "targetText": "Have you ever eaten sushi?",
      "transliteration": "ハヴ ユー エヴァー イートン スシ？",
      "baseTranslation": "今までに寿司を食べたことはありますか？"
    },
    {
      "wordId": "v2",
      "targetText": "I have seen that movie before.",
      "transliteration": "アイ ハヴ シーン ザット ムーヴィー ビフォア",
      "baseTranslation": "私は以前その映画を見たことがあります。"
    },
    {
      "wordId": "v3",
      "targetText": "I have never been to London.",
      "transliteration": "アイ ハヴ ネヴァー ビーン トゥ ロンドン",
      "baseTranslation": "私は一度もロンドンに行ったことがありません。"
    },
    {
      "wordId": "v6",
      "targetText": "This house was built in 1990.",
      "transliteration": "ディス ハウス ワズ ビルト イン ナインティーン ナインティ",
      "baseTranslation": "この家は1990年に建てられました。"
    },
    {
      "wordId": "v7",
      "targetText": "This car is made in Japan.",
      "transliteration": "ディス カー イズ メイド イン ジャパン",
      "baseTranslation": "この車は日本製（日本で作られている）です。"
    },
    {
      "wordId": "v8",
      "targetText": "The book was written by him.",
      "transliteration": "ザ ブック ワズ リトゥン バイ ヒム",
      "baseTranslation": "その本は彼によって書かれました。"
    },
    {
      "wordId": "v11",
      "targetText": "I have never done that.",
      "transliteration": "アイ ハヴ ネヴァー ダン ザット",
      "baseTranslation": "私はそれを一度もやったことがありません。"
    }
  ],
