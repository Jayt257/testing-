  "exampleSentences": [
    {
      "wordId": "v1",
      "targetText": "I have a terrible headache.",
      "transliteration": "アイ ハヴ ア テリブル ヘッドエイク",
      "baseTranslation": "ひどい頭痛があります。"
    },
    {
      "wordId": "v3",
      "targetText": "My left leg hurts.",
      "transliteration": "マイ レフト レッグ ハーツ",
      "baseTranslation": "左足が痛みます。"
    },
    {
      "wordId": "v6",
      "targetText": "I am allergic to peanuts.",
      "transliteration": "アイ アム アラージック トゥ ピーナッツ",
      "baseTranslation": "私はピーナッツアレルギーです。"
    },
    {
      "wordId": "v7",
      "targetText": "The doctor gave me a prescription.",
      "transliteration": "ザ ドクター ゲイヴ ミー ア プリスクリプション",
      "baseTranslation": "医者は私に処方箋をくれました。"
    },
    {
      "wordId": "v9",
      "targetText": "Take one pill twice a day.",
      "transliteration": "テイク ワン ピル トゥワイス ア デイ",
      "baseTranslation": "1日2回、1錠を服用してください。"
    },
    {
      "wordId": "v10",
      "targetText": "Please call an ambulance!",
      "transliteration": "プリーズ コール アン アンビュランス！",
      "baseTranslation": "救急車を呼んでください！"
    },
    {
      "wordId": "v13",
      "targetText": "Do you have travel insurance?",
      "transliteration": "ドゥー ユー ハヴ トラベル インシュランス？",
      "baseTranslation": "旅行保険には入っていますか？"
    }
  ],
