  "exampleSentences": [
    {
      "wordId": "v1",
      "targetText": "If it is sunny, I will go out.",
      "transliteration": "イフ イット イズ サニー、アイ ウィル ゴー アウト",
      "baseTranslation": "もし晴れたら、外出します。"
    },
    {
      "wordId": "v4",
      "targetText": "If you are cold, close the window.",
      "transliteration": "イフ ユー アー コールド、クローズ ザ ウィンドウ",
      "baseTranslation": "もし寒ければ、窓を閉めてください。"
    },
    {
      "wordId": "v6",
      "targetText": "I will sleep early if I am tired.",
      "transliteration": "アイ ウィル スリープ アーリー イフ アイ アム タイアード",
      "baseTranslation": "もし疲れていたら、早く寝ます。"
    },
    {
      "wordId": "v9",
      "targetText": "When I arrive, I will call you.",
      "transliteration": "ウェン アイ アライヴ、アイ ウィル コール ユー",
      "baseTranslation": "到着したら（した時）、電話します。"
    },
    {
      "wordId": "v10",
      "targetText": "If the traffic is bad, we will be late.",
      "transliteration": "イフ ザ トラフィック イズ バッド、ウィー ウィル ビー レイト",
      "baseTranslation": "もし渋滞がひどければ、遅れます。"
    }
  ],
