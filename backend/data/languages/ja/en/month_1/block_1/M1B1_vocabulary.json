      "baseTranslation": "行かなきゃ。またね！"
    },
    {
      "wordId": "v7",
      "targetText": "Turn right at the corner.",
      "transliteration": "ターン ゥライト アット ザ コーナー",
      "baseTranslation": "角を右に曲がってください。"
    },
    {
      "wordId": "v9",
      "targetText": "Thank you very much.",
      "transliteration": "サンキュー ヴェリー マッチ",
      "baseTranslation": "どうもありがとうございます。"
    },
