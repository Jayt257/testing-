          "questionHints": null,
          "marks": 10,
          "correctAnswerRef": "adminCorrectAnswerSet.answerKey.q1"
        },
        {
          "questionId": "q2",
          "questionText": "「Right（右）」を発音するとき、舌はどうなりますか？ (What happens to your tongue when pronouncing 'Right'?)",
          "questionType": "multiple_choice",
          "options": [
            "上の歯の裏に押し当てる (Press against back of upper teeth)",
            "どこにも当てず、口の奥に引く (Pull back without touching anywhere)",
