      "questions": [
        {
          "questionId": "q1",
          "questionText": "V を発音するとき、正しい口の形はどれですか？ (What is the correct mouth shape for 'V'?)",
          "questionType": "multiple_choice",
          "options": [
            "両方の唇を閉じる (Close both lips)",
            "上の前歯で下唇を軽く噛む (Bite lower lip with upper teeth)",
            "舌を上の歯の裏につける (Put tongue behind upper teeth)",
            "舌を歯で挟む (Put tongue between teeth)"
