  "exampleSentences": [
    {
      "wordId": "w01",
      "targetText": "मैं अगले महीने भारत जाऊँगी।",
      "transliteration": "Main agle maheene Bhaarat jaaoongee.",
      "baseTranslation": "私は来月インドへ行きます(女)。"
    },
    {
      "wordId": "w06",
      "targetText": "हम कल यहाँ मिलेंगे।",
      "transliteration": "Hum kal yahaan milenge.",
      "baseTranslation": "私たちは明日ここで会う予定です。"
    },
    {
      "wordId": "w08",
      "targetText": "वे क्या करेंगे?",
      "transliteration": "Ve kyaa karenge?",
      "baseTranslation": "彼ら（またはあの方）は何をする予定ですか？"
    }
  ],
