      "syllableSplit": "THIS",
      "nativeAudioRef": "audioAssets.nativeAudio",
      "slowAudioRef": "audioAssets.slowAudio",
      "commonMispronunciation": "Saying 'Dis' or stretching the 'i' to sound like 'Thees'."
